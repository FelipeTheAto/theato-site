---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Produtora cultural de artes cênicas. Teatro, música e dança com propósito.' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://theato.com.br" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:image" content="https://theato.com.br/images/og-theato.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://theato.com.br/images/og-theato.jpg" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'TheAto Produções',
      url: 'https://theato.com.br',
      email: 'administrativo@theato.com.br',
      telephone: '+55 45 98803-5720',
      sameAs: ['https://instagram.com/theatoproducoes'],
      description: 'Produtora cultural de artes cênicas. Teatro, música e dança com propósito.',
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;700;900&family=Caveat:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="bg-brand-beige text-brand-black font-body">
    <div class="grain-overlay" aria-hidden="true"></div>
    <slot />

    <!-- Fade-in on scroll observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1 }
      );

      document.querySelectorAll('.fade-in').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
