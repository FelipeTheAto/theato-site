---
// Contact section — dark background, direct info
---

<section id="contato" class="bg-brand-black text-white relative">
  <!-- Red divider line -->
  <div class="h-1 bg-brand-red w-full"></div>

  <div class="py-24 md:py-32 lg:py-40 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="fade-in font-display font-black text-4xl md:text-5xl lg:text-6xl uppercase tracking-tight mb-12 md:mb-16">
        Vamos conversar.
      </h2>

      <div class="fade-in space-y-6 text-lg md:text-xl">
        <div class="flex items-center gap-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-red flex-none">
            <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <a href="mailto:administrativo@theato.com.br" class="hover:text-brand-red transition-colors">
            administrativo@theato.com.br
          </a>
        </div>

        <div class="flex items-center gap-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-red flex-none">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />
          </svg>
          <a href="tel:+5545988035720" class="hover:text-brand-red transition-colors">
            (45) 98803-5720
          </a>
        </div>

        <div class="flex items-center gap-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-red flex-none">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
          <a href="https://instagram.com/theatoproducoes" target="_blank" rel="noopener noreferrer" class="hover:text-brand-red transition-colors">
            @theatoproducoes
          </a>
        </div>

        <div class="flex items-center gap-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand-red flex-none">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <span class="text-white/80">Cascavel, PR</span>
        </div>
      </div>
    </div>
  </div>
</section>
