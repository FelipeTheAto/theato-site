---
// Prova social — números do primeiro universo. Sem adjetivo: o número fala.
const stats = [
  {
    value: '99,7',
    unit: '/100',
    label: 'Nota da Lebre no País do Chá na avaliação da PNAB',
  },
  {
    value: '17.04',
    unit: '.2026',
    label: 'Estreia do primeiro espetáculo da TheAto',
  },
  {
    value: 'Em circulação',
    unit: '',
    label: 'A Lebre segue em temporada pelo Paraná',
  },
];
---

<section class="bg-brand-black text-white py-20 md:py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      {stats.map((stat) => (
        <div class="fade-in text-center md:text-left md:border-l-4 md:border-brand-red md:pl-6">
          <p class="font-display font-black text-4xl md:text-5xl lg:text-6xl text-brand-red leading-none tracking-tight">
            {stat.value}<span class="text-white/40 text-2xl md:text-3xl lg:text-4xl">{stat.unit}</span>
          </p>
          <p class="mt-4 font-body text-base md:text-lg text-white/70 leading-relaxed">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
